# ============================================================
#  LAB7DEPAZ Backend — Environment Variables
#  Copy this file to .env and fill in your real values
#  NEVER commit .env to git!
# ============================================================

# Server
NODE_ENV=development
PORT=4000
# Set this to your public Render URL in production (used by Swagger UI)
APP_URL=http://localhost:4000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=lab7depaz

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# CORS — set this to your deployed Angular frontend URL in production
CORS_ORIGIN=http://localhost:4200

# Email (Ethereal for dev/testing — get free creds at https://ethereal.email)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
EMAIL_FROM=no-reply@lab7depaz.com
